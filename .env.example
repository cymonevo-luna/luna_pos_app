# Copy this file to `.env` and fill in per-environment values.
# `.env` is git-ignored; `.env.example` is committed as a template.

# Base URL of the luna_pos_service backend.
# Deployed backend (HTTPS). For local dev against the host instead, use:
#   Android emulator -> host machine: http://10.0.2.2:8087
#   iOS simulator / desktop / web:     http://localhost:8087
API_BASE_URL=http://10.0.2.2:8087

# Leave empty to disable Sentry error reporting.
SENTRY_DSN=

# One of: dev | staging | prod
APP_ENV=dev
