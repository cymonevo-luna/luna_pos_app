[Unit]
Description=Luna shared Android emulator for Flutter agent testing
After=network.target

[Service]
Type=oneshot
RemainAfterExit=yes
Environment=ANDROID_HOME=%h/Android/Sdk
Environment=ANDROID_SDK_ROOT=%h/Android/Sdk
Environment=SHARED_AVD=Pixel_9_Pro
ExecStart=%h/Codes/cymonevo/luna/flutter_template/scripts/start-shared-emulator.sh
ExecStop=%h/Codes/cymonevo/luna/flutter_template/scripts/stop-shared-emulator.sh

[Install]
WantedBy=default.target
